# ══════════════════════════════════════════════════════════════════
# O.P.U.C — .gitignore (monorepo frontend/ + backend/)
# ══════════════════════════════════════════════════════════════════

# ─── Secrets (NEVER commit) ─────────────────────────────────────
.env
.env.*
!.env.example
*.pid
*.key
*.pem

# ─── Frontend (Next.js) ─────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/.wrangler/
frontend/open-next/
frontend/.turbo/
frontend/next-env.d.ts
frontend/*.tsbuildinfo

# ─── Backend (Go) ───────────────────────────────────────────────
backend/bin/
backend/opuc-api
backend/*.exe
backend/vendor/
*.test
*.out

# ─── Logs / tmp ─────────────────────────────────────────────────
*.log
dev.log
backend.log
/tmp/
coverage/
.coverage
htmlcov/

# ─── OS / éditeurs ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-*

# ─── Sandbox / CI artifacts ─────────────────────────────────────
.zscripts/
tool-results/
download/
upload/
examples/
mini-services/
skills/
Caddyfile
worklog.md
next-env.d.ts

# Build artifacts
.wrangler/
