# ══════════════════════════════════════════════════════════════════
# O.P.U.C — Frontend Next.js — Environment Variables Template
# ══════════════════════════════════════════════════════════════════
#
# Copier ce fichier en .env.local et adapter :
#   cp .env.example .env.local
#
# Le frontend ne nécessite QUE ces variables car :
#   - L'auth est gérée par le backend Go (cookie httpOnly)
#   - Les appels API passent par /api/v1/* (proxy vers backend)
#   - Prisma a été retiré (plus de DATABASE_URL côté frontend)
# ══════════════════════════════════════════════════════════════════

# ─── NEXTAUTH (legacy, à retirer après cleanup complet) ─────────
# Conservé pour compatibilité pendant la transition
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# ─── API GO (proxy via next.config.ts rewrites) ─────────────────
# Le frontend appelle /api/v1/* qui est proxyé vers http://localhost:8080
# Aucune variable d'env nécessaire — le proxy est configuré dans next.config.ts
