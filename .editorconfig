# EditorConfig — https://editorconfig.org
# Maintient une cohérence de style entre éditeurs et IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ─── Go ─────────────────────────────────────────────────────────
[*.go]
indent_style = tab
indent_size = 4

# ─── Makefile ───────────────────────────────────────────────────
[Makefile]
indent_style = tab

# ─── Markdown ───────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─── YAML ───────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_size = 2

# ─── JSON ───────────────────────────────────────────────────────
[*.json]
indent_size = 2

# ─── SQL ────────────────────────────────────────────────────────
[*.sql]
indent_size = 2
