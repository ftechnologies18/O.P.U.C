# ══════════════════════════════════════════════════════════════════
# O.P.U.C — Backend API Go — Variables d'environnement
# ══════════════════════════════════════════════════════════════════
# Copier en .env et adapter :
#   cp .env.example .env

# ─── SERVEUR HTTP ───────────────────────────────────────────────
PORT=8080
APP_ENV=development

# ─── BASE DE DONNÉES SUPABASE ───────────────────────────────────
# DATABASE_URL : connexion runtime (rôle app_user, RLS appliquée)
# Format : postgresql://app_user:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://app_user:opuc_app_user_dev_change_me@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# MIGRATIONS_URL : connexion admin (rôle postgres, bypass RLS)
# Utilisée pour AutoMigrate + opérations admin
MIGRATIONS_URL=postgresql://postgres.oiruwlbvfmlvhbarjnlr:Victoire%401993%23@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ─── JWT ────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
JWT_SECRET=opuc-super-secret-change-in-production-2025
JWT_EXPIRATION_HOURS=24

# ─── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── LOGGING ────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=debug
